OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-api-key
GOOGLE_APPLICATION_CREDENTIALS=google_credentials.json
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
ELEVENLABS_API_KEY=your-elevenlabs-api-key
TRANSLATE_LANGUAGES="en-US,cmn-Hant-TW"
COMMON_PROMPT="open source 開源,hackathon 黑客松,code 程式碼,g0v 零時政府"
# Personal API key from the user dashboard (/user-dashboard → API Key). The
# account must own (or co-own) the target room to push subtitles into it.
# Security: use a DEDICATED NON-admin account for this machine — the key only
# needs room ownership. (Admin management endpoints are refused for key-based
# callers, but least privilege is still the right posture if the box is stolen.)
# The key is sent once at connect, not on every update.
API_KEY=otl_your-personal-api-key